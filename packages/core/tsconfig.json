{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../../lib/tifa-core/**/*.ts",
    "../../lib/framework/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
