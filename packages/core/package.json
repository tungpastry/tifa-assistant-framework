{
  "name": "@tifa-assistant/core",
  "version": "0.1.0",
  "description": "Core contracts and framework metadata for Tifa Assistant Framework.",
  "type": "module",
  "main": "./dist/packages/core/src/index.js",
  "types": "./dist/packages/core/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/core/src/index.d.ts",
      "default": "./dist/packages/core/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run build"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
