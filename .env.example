# Tifa Assistant Framework Environment Variables
# Use this file as a template for your own .env file.
# Do not commit .env to version control.

# -- Core Settings
TIFA_TIMEZONE=Asia/Ho_Chi_Minh
TIFA_RUNTIME_DIR=runtime
HOST=0.0.0.0
PORT=3100
TIFA_BASE_URL=http://127.0.0.1:3100

# -- Optional SaaS Mode
# Local-first mode is the default. Leave these disabled unless PostgreSQL,
# Redis, object storage, auth, and tenant operations are intentionally wired.
TIFA_RUNTIME_MODE=local
TIFA_SAAS_MODE=0
TIFA_LOCAL_FIRST=1
TIFA_DEFAULT_TENANT_ID=local
TIFA_DEFAULT_ASSISTANT_ID=tifa-assistant
TIFA_DEFAULT_LOCALE=en-US

TIFA_PG_ENABLED=0
TIFA_PG_CONNECTION_STRING=
TIFA_PG_ALLOWED_VIEWS=v_market_bars,v_latest_news,v_symbol_daily_stats,v_macro_calendar,v_sentiment_rollup,v_fx_market_snapshots,v_fx_latest_news,v_fx_symbol_daily_stats,v_fx_macro_calendar,v_fx_sentiment_rollup
TIFA_PG_MAX_ROWS=500
TIFA_PG_STATEMENT_TIMEOUT_MS=4000
TIFA_PG_POOL_MAX=4
TIFA_PG_CONNECT_TIMEOUT_MS=3000
TIFA_PG_IDLE_TIMEOUT_MS=30000
TIFA_PG_SSL=0
TIFA_REDIS_ENABLED=0
TIFA_OBJECT_STORAGE_ENABLED=0
TIFA_TEXT_TO_SQL_ENABLED=0
TIFA_VIENEU_ENABLED=0

# -- Local AI Services
OLLAMA_URL=http://127.0.0.1:11434
TIFA_API_URL=http://127.0.0.1:11434/api/generate
TIFA_MODEL=gemma3:1b
TIFA_TIMEOUT_MS=20000
TIFA_PROMPT_PATH=prompts/TIFA_RUNTIME.md
TIFA_LLM_ROUTING_POLICY=local-first
TIFA_LLM_PROVIDER=ollama
TIFA_LLM_FALLBACK_ORDER=ollama,qwen,openai,gemini

# -- Optional Cloud LLM Providers
# Leave these empty for local-first mode. Health reports disabled providers
# unless credentials or endpoints are configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
QWEN_API_KEY=
QWEN_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# -- Piper TTS (Text-to-Speech)
PIPER_BIN=/home/nexus/piper-env/bin/piper
PIPER_MODEL=/home/nexus/piper/voices/en_US-libritts-high.onnx
PIPER_TIMEOUT_MS=10000

# -- API Rate Limits
TIFA_RATE_LIMIT_WINDOW_MS=60000
TIFA_RATE_LIMIT_MAX=20
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX=10

# -- Runtime Cleanup
TIFA_CLEANUP_DRY_RUN=1
TIFA_AUDIO_CACHE_RETENTION_DAYS=30
TIFA_TTS_JOB_RETENTION_DAYS=7
TIFA_LOG_RETENTION_DAYS=30
TIFA_TTS_WORKER_INTERVAL_MS=1000
